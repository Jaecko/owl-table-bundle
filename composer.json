{
    "name": "owl-concept/table-bundle",
    "description": "A reusable Twig component for generating dynamic HTML tables in Symfony",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/twig-bundle": "^6.4 || ^7.0",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "OwlConcept\\TableBundle\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "require": "^6.4 || ^7.0"
        }
    }
}
